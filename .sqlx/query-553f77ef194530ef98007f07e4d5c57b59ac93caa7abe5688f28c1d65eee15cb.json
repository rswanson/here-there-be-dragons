  "query": "UPDATE characters SET\n            name = COALESCE($2, name),\n            portrait_asset_id = CASE WHEN $3 THEN $4 ELSE portrait_asset_id END,\n            visible_to_players = COALESCE($5, visible_to_players),\n            updated_at = now()\n        WHERE id = $1\n        RETURNING *",
