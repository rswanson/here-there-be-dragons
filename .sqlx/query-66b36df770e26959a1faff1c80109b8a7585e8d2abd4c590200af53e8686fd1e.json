  "query": "SELECT t.id, t.layer_id, t.name, t.asset_id, t.owner_id,\n                  t.x, t.y, t.size, t.rotation, t.bars_json,\n                  t.status_markers, t.created_at, t.updated_at\n           FROM tokens t\n           JOIN map_layers l ON t.layer_id = l.id\n           WHERE l.map_id = $1\n           ORDER BY t.created_at ASC",
