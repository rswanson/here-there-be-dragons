{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id, c.name, c.owner_id, c.invite_code, c.created_at, c.updated_at\n        FROM campaigns c\n        JOIN campaign_members cm ON c.id = cm.campaign_id\n        WHERE cm.user_id = $1\n        ORDER BY c.updated_at DESC\n        ",
