{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, campaign_id, uploaded_by, filename, content_type, storage_path, size_bytes, created_at\n        FROM assets\n        WHERE campaign_id = $1\n        AND ($2::text IS NULL OR content_type LIKE $2)\n        ORDER BY created_at DESC\n        LIMIT $3 OFFSET $4\n        ",
