  "query": "UPDATE handouts SET\n            title = COALESCE($2, title),\n            content = COALESCE($3, content),\n            visibility = COALESCE($4, visibility),\n            player_ids = CASE WHEN $5 THEN $6 ELSE player_ids END,\n            updated_at = now()\n        WHERE id = $1\n        RETURNING *",
