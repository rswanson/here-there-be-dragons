  "query": "SELECT * FROM chat_messages\n           WHERE campaign_id = $1\n             AND created_at < (SELECT created_at FROM chat_messages WHERE id = $3)\n             AND (message_type != 'whisper' OR sender_user_id = $2 OR $2 = ANY(whisper_target_ids))\n           ORDER BY created_at DESC\n           LIMIT $4",
