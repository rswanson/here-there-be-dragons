  "query": "\n        SELECT cm.campaign_id, cm.user_id, cm.role, cm.joined_at, u.display_name\n        FROM campaign_members cm\n        JOIN users u ON cm.user_id = u.id\n        WHERE cm.campaign_id = $1\n        ORDER BY cm.joined_at\n        ",
